{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": "allow",
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "task": "allow",
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
